---
const base = import.meta.env.BASE_URL;
const withBase = (path) => {
  const clean = path.startsWith('/') ? path.slice(1) : path;
  return `${base}${clean}`;
};
---
<footer class="footer-main">
  <div class="container footer-main-inner">
    <div>
      <div class="footer-col-title">Asset Site</div>
      <div class="footer-brand">Vepoloxamer</div>
    </div>

    <div>
      <div class="footer-col-title">Explore</div>
      <nav class="footer-links two-col" aria-label="Footer">
        <a href={withBase('science/')}>The Science</a>
        <a href={withBase('development/')}>Development Path</a>
        <a href={withBase('preclinical/')}>Preclinical Evidence</a>
        <a href={withBase('about-liferaft/')}>About LifeRaft Biosciences</a>
        <a href={withBase('clinical-history/')}>Clinical History</a>
        <a href={withBase('partner/')}>Partnership Opportunities</a>
        <a href={withBase('ip-protection/')}>IP & Patent Protection</a>
      </nav>
    </div>

    <div class="footer-actions">
      <div class="footer-col-title">Connect</div>
      <a class="button primary" href={withBase('partner/')}>Schedule a Discussion</a>
      <a class="button dark-outline" href="mailto:info@liferaftbiosciences.com">Email Us</a>
    </div>
  </div>

  <div class="container">
    <div class="footer-legal">
      © 2026 Liferaft Biosciences. All Rights Reserved. |
      <a href="https://liferaftbiosciences.com/privacy-policy/">Privacy Policy</a><br />
      Property of LifeRaft Biosciences, Inc., and its affiliates, including Hirodika Biosciences, Inc.
    </div>
  </div>
</footer>
