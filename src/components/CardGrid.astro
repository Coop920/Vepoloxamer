---
interface Item {
  icon?: string;
  title: string;
  body: string;
  tag?: string;
  href?: string;
  centered?: boolean;
  borderTopColor?: string;
}
interface Props {
  columns?: 2 | 3;
  items: Item[];
}
const { columns = 3, items } = Astro.props;
---
<div class:list={['grid', columns === 2 ? 'grid-2' : 'grid-3']}>
  {items.map((item) => (
    <article
      class:list={['card', item.centered && 'metric-card']}
      style={item.borderTopColor ? `border-top: 3px solid ${item.borderTopColor};` : undefined}
    >
      {item.icon && <div class="card-icon">{item.icon}</div>}
      <h3 class="card-title" set:html={item.title} />
      <p>{item.body}</p>
      {item.tag && (
        item.href ? <a class="tag" href={item.href}>{item.tag}</a> : <div class="tag">{item.tag}</div>
      )}
    </article>
  ))}
</div>
