---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import PageHero from '../components/PageHero.astro';
import FooterStrip from '../components/FooterStrip.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteCtaBand from '../components/SiteCtaBand.astro';
import ContentSection from '../components/ContentSection.astro';
import MetricGrid from '../components/MetricGrid.astro';
import AssetHighlight from '../components/AssetHighlight.astro';

const metrics = [
  {
    icon: '👥',
    value: '~4,000<sup>*</sup>',
    body: 'Total patients exposed across decades of poloxamer clinical research (purified and non-purified forms) — see footnote on Home page for full breakdown.'
  },
  {
    icon: '📄',
    value: 'One Filed IND +<br/>Draft INDs',
    body: 'One complete filed IND (EPIC trial IND) is included in the asset transfer, along with a draft IMPD (Heart Failure; drafted but not submitted). A meaningful regulatory head-start — existing safety data and protocols compress the work required to file a new IND for the lead indication.'
  },
  {
    icon: '🏭',
    value: 'Established<br/>Manufacturing Process',
    body: 'The drug manufacturing process is well-characterized and documented. The supply chain can be reestablished through experienced global CDMOs without starting from scratch.'
  }
];
---
<BaseLayout title="Vepoloxamer | Clinical History">
  <SiteHeader />
  <PageHero
    eyebrow="Section 04 — Clinical History"
    title="Not a Paper Drug:<br><em>A Deep Human Evidence Base — Including INDs, Clinical Datasets, and an Established Manufacturing Process</em>"
    intro="Vepoloxamer has been studied in human clinical trials for over three decades. The asset includes Investigational New Drug files, extensive human safety and pharmacokinetic datasets, and a well-characterized manufacturing process that can be reestablished through established global CDMOs."
  />

  <ContentSection>
    <MetricGrid items={metrics} />
  </ContentSection>

  <ContentSection>
    <AssetHighlight
      eyebrow="Asset Value — Established Manufacturing Process"
      title="A Well-Characterized Supply Chain That Can Be Reestablished Efficiently"
      body={[
        'Vepoloxamer’s drug manufacturing process is well-characterized and fully documented. The process has been successfully implemented at commercial scale by qualified contract development and manufacturing organizations with global reach and decades of experience in pharmaceutical manufacturing.',
        'A strategic acquirer therefore inherits more than a scientific thesis: it inherits a practical supply-chain head start that shortens the path back into clinic.'
      ]}
      bullets={[
        'Analytical specifications are defined.',
        'The purification method is documented.',
        'The process has previously been run at commercial scale.',
        'Reestablishment with an experienced CDMO is materially faster than building a brand-new manufacturing path.'
      ]}
    />
  </ContentSection>

  <ContentSection
    eyebrow="Clinical History"
    subtitle="Development History: From P-188 to Vepoloxamer"
    intro="There have been two distinct Phase III sickle cell trials across this molecule’s history — conducted 15 years apart, by different sponsors, with different compounds, different designs, and different lessons. Understanding that distinction is essential context for any serious investor."
  >
    <div class="timeline">
      <div class="timeline-item">
        <div class="timeline-year">1980s — Sponsor: CytRx Corporation / Burroughs Wellcome</div>
        <h4>P-188 (Non-Purified) — Orphan Drug Designation &amp; Phase 2 Sickle Cell Pilot</h4>
        <p>Dr. Robert Hunter at Emory University identified poloxamer 188’s rheologic, cytoprotective, and antithrombotic properties. His work led to the formation of CytRx Corporation, which licensed the inventions from Emory and developed the drug under the name <em>RheothRx</em>. CytRx secured FDA Orphan Drug Designation for sickle cell disease in 1989 and formed a major research alliance with Burroughs Wellcome.</p>
        <p>Burroughs Wellcome then conducted a Phase 2 pilot study in sickle cell disease using non-purified P-188, showing reduced VOC duration, reduced pain intensity, and reduced analgesic use in patients receiving the full dose. Encouraged by those results, the sponsor initiated a large acute myocardial infarction trial program.</p>
        <div class="outcome-panel">⚠ Renal toxicity in the large AMI lead-in study (roughly 3,000 patients) halted the program. CytRx determined the cause: low-molecular-weight impurities in commercial-grade P-188 caused reversible osmotic nephrosis through kidney proximal tubule accumulation. Glaxo returned the program to CytRx.</div>
      </div>

      <div class="timeline-item">
        <div class="timeline-year">Early 1990s — Sponsor: CytRx Corporation</div>
        <h4>The Purification Breakthrough — Birth of Vepoloxamer</h4>
        <p>CytRx developed a proprietary manufacturing method using supercritical fluid chromatography to remove the low-molecular-weight impurities from commercial P-188. The resulting purified compound eliminated the renal-accumulation problem while maintaining therapeutic activity at higher doses.</p>
        <p>This purified entity was later assigned the USAN name <strong>vepoloxamer</strong>. It is this purified compound, and its manufacturing method, that the Composition of Matter patent protects.</p>
        <div class="outcome-panel good">✓ Purification resolved the AMI-era safety problem. The molecule that went forward into subsequent trials became fundamentally different from commercial poloxamer 188.</div>
      </div>

      <div class="timeline-item timeline-accent-blue">
        <div class="timeline-year" style="color: var(--cerulean); letter-spacing: 0.12rem;">Phase III Trial #1 — 1998–1999 — Sponsor: CytRx Corporation</div>
        <h4>CytRx Phase III Sickle Cell Trial (Purified P-188 / Pre-Vepoloxamer INN)</h4>

        <div class="grid grid-2" style="margin-top: 0.9rem;">
          <div class="phase-card">
            <div class="phase-card-title blue">Trial Design</div>
            <ul class="checklist">
              <li>Randomized, double-blind, placebo-controlled</li>
              <li>Conducted at 40 US medical centers</li>
              <li>Enrollment: March 1998 – October 1999</li>
              <li>Patients: n=255 (planned n=350 — concluded early)</li>
              <li>Ages: 9–53 years</li>
              <li>Drug: purified poloxamer 188, 100 mg/kg load (1h) then 30 mg/kg/h (47h)</li>
              <li>PI: E.P. Orringer, MD (University of North Carolina)</li>
            </ul>
          </div>

          <div class="phase-card">
            <div class="phase-card-title blue">Primary Endpoint &amp; Result</div>
            <ul class="checklist">
              <li>Endpoint: duration of painful episode from randomization to crisis resolution</li>
              <li>Primary endpoint not met — 9-hour reduction, not statistically significant at n=255</li>
              <li>Trial ended early because of capital constraints, not safety</li>
              <li>Post-hoc responder analysis: 50% vepoloxamer vs. 37% placebo achieved crisis resolution within 168h (p=0.02)</li>
              <li>Subgroup signals in children and hydroxyurea co-treatment were stronger</li>
            </ul>
          </div>
        </div>

        <div class="outcome-panel">
          <strong>Why it missed:</strong> the trial was underpowered. Enrollment stopped at 255 of the planned 350 patients because of capital constraints, not safety. Endpoint design limitations also compressed the apparent effect.
          <br /><br />
          <strong>Corporate fate:</strong> after the trial, CytRx merged with a private company and discontinued existing programs including vepoloxamer. In 2004, a group including Dr. Hunter formed <strong>SynthRx, Inc.</strong> and acquired all rights to the compound’s data, know-how, and IP from CytRx.
          <br /><br />
          <strong>Publication:</strong> Orringer EP et al. <em>JAMA.</em> 2001;286(17):2099–2106. PMID: 11694150.
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-year">2004–2010 — SynthRx, Inc. / Adventrx Pharmaceuticals</div>
        <h4>Asset Consolidation &amp; IP Strengthening</h4>
        <p>SynthRx acquired all rights from CytRx in 2004. In 2010, Adventrx Pharmaceuticals acquired SynthRx, renamed the compound ANX-188, and began preclinical and FDA-interaction work. Adventrx later renamed itself Mast Therapeutics.</p>
        <div class="outcome-panel">New intellectual property was developed and filed. The Composition of Matter patent application advanced. There was no clinical activity during this period.</div>
      </div>

      <div class="timeline-item timeline-accent-gold highlight">
        <div class="timeline-year" style="color: var(--gold); letter-spacing: 0.12rem;">Phase III Trial #2 — 2013–2016 — Sponsor: Mast Therapeutics (NYSE: MSTX)</div>
        <h4>EPIC Trial — Evaluation of Purified Poloxamer 188 in Vaso-Occlusive Crisis</h4>
        <p><strong>How it differed from Trial #1:</strong> Mast designed EPIC specifically to address the two known weaknesses of the CytRx trial — statistical underpowering and endpoint ambiguity. GMP manufacturing was reestablished from scratch with partner <strong>Pierre Fabre</strong> using the proprietary purification process. FDA provided written agreement on the design before initiation.</p>

        <div class="grid grid-2" style="margin-top: 0.9rem;">
          <div class="phase-card" style="background: var(--cream);">
            <div class="phase-card-title gold">Trial Design</div>
            <ul class="checklist">
              <li>Randomized, double-blind, placebo-controlled</li>
              <li>75 sites across 14 countries</li>
              <li>Enrollment: January 2013 – February 2016</li>
              <li>Patients: n=388</li>
              <li>Ages: 4–46 years (predominantly pediatric)</li>
              <li>Drug: vepoloxamer (MST-188), same dosing regimen</li>
              <li>PI: James F. Casella, MD (Johns Hopkins)</li>
              <li>New primary endpoint: time to last parenteral opioid</li>
            </ul>
          </div>

          <div class="phase-card" style="background: var(--cream);">
            <div class="phase-card-title gold">Primary Endpoint &amp; Result</div>
            <ul class="checklist">
              <li>Endpoint: duration of VOC (time to last parenteral opioid)</li>
              <li>Primary endpoint not met — 82h vepoloxamer vs. 78h placebo (p=0.09)</li>
              <li>Vepoloxamer arm was numerically longer — unexpected and poorly understood</li>
              <li>Safety remained clean: no deaths and no significant AE differential vs. placebo</li>
              <li>No significant secondary-endpoint differences in re-hospitalization or acute chest syndrome</li>
            </ul>
          </div>
        </div>

        <div class="outcome-panel">
          <strong>Why it missed — and what it means:</strong> unlike the CytRx trial, EPIC was adequately powered. The effect was genuinely not detected in this design and endpoint, in this patient population. The 82h vs. 78h result remains complex and should be owned directly.
          <br /><br />
          <strong>What EPIC generated:</strong> the world’s largest placebo-controlled vaso-occlusive crisis dataset, one complete filed IND, a draft heart-failure IMPD, and comprehensive human safety and PK characterization — all of which transferred with the asset.
          <br /><br />
          <strong>Publication:</strong> Casella JF et al. <em>JAMA.</em> 2021;325(15):1513–1523. PMID: 33877274. doi:10.1001/jama.2021.3414.
        </div>
      </div>

      <div class="timeline-item">
        <div class="timeline-year">2020 — Vepoloxamer Heart Failure Study · Published Data</div>
        <h4>Vepoloxamer in Heart Failure — Rapid, Sustained Improvement in Cardiac Function</h4>
        <p>In a canine microembolization heart failure model, vepoloxamer at 450 mg/kg improved left ventricular ejection fraction by 11 absolute percentage points within 2 hours, with benefits persisting for one week after a single infusion. A pulsed-therapy paradigm sustained benefit through six weeks.</p>
        <p style="font-size: 0.9rem;"><strong>Note:</strong> Mast Therapeutics also initiated a Phase 2 chronic heart failure study that enrolled 10 patients before termination for business and strategic reasons rather than safety concerns.</p>
        <div class="outcome-panel good">✓ Published vepoloxamer-specific data showing acute and sustained cardiac functional improvement. Pulsed dosing suggests viability for chronic-disease management. The draft heart-failure IMPD remains part of the transferred asset package.</div>
        <p style="font-size: 0.85rem; color: var(--muted); font-style: italic;">Sabbah HN et al. Acute and sustained hemodynamic effects of poloxamer 188 in an experimental model of heart failure. <em>Cardiovasc Drugs Ther.</em> 2020;34(6):783–792. PMID: 32146638.</p>
      </div>

      <div class="timeline-item">
        <div class="timeline-year">2017 — Asset Acquisition · LifeRaft Biosciences</div>
        <h4>Full Asset Acquisition — LifeRaft Acquires Vepoloxamer from Savara</h4>
        <p>Following the EPIC program termination in September 2016, Mast Therapeutics merged with Savara Inc. in April 2017, at which point the asset transferred to Savara. LifeRaft subsequently acquired Vepoloxamer from Savara under the terms of an Asset Purchase Agreement in October 2017.</p>
        <p>The transferred package included the Composition of Matter patent, one complete filed IND, a draft IMPD, clinical records and data from prior programs, manufacturing process documentation and formulation know-how, and the published scientific literature base.</p>
      </div>

      <div class="timeline-item highlight">
        <div class="timeline-year">2017 — Present · LifeRaft Biosciences &amp; MUSC</div>
        <h4>Value Creation: New Indication Development &amp; Method of Use Patent Application</h4>
        <p>Since acquiring the asset, LifeRaft has actively advanced Vepoloxamer into a new and commercially differentiated indication — <strong>radioprotection</strong> — in collaboration with the Medical University of South Carolina. This represents genuine post-acquisition value creation: a new clinical hypothesis, new preclinical studies, and a new IP layer.</p>
        <p>Preclinical studies through the LifeRaft / MUSC collaboration demonstrated systemic radioprotectant activity — protecting non-insulted tissue from collateral radiation damage. Those results are referenced elsewhere on the site as a new indication thesis developed under LifeRaft ownership.</p>

        <div class="detail-box">
          <div class="detail-box-title">IP Created Post-Acquisition — Method of Use Patent Application</div>
          <p>Based on the MUSC collaboration studies, MUSC filed a Method of Use patent application covering administration of Vepoloxamer (P188) as a radioprotectant — specifically protecting non-insulted cells from radiation damage via pre-exposure administration within a defined dosing and timing protocol.</p>
          <p><strong>LifeRaft holds an exclusive license to this patent application, and any patents issuing therefrom,</strong> including sublicense rights. The license also covers associated Know-How within the therapeutic field of use.</p>

          <div class="license-grid">
            <div class="license-box">
              <div class="license-box-title">Patent Scope</div>
              Method of preventing damage to non-insulted cells during or after radiation exposure · Vepoloxamer administered prior to exposure · Dosing: 10–150 mg/kg · Administration window: within 0–48 hours · Single-dose protocol (no re-dosing within 14 hours)
            </div>
            <div class="license-box">
              <div class="license-box-title">LifeRaft License Rights</div>
              Exclusive license under the patent application and any issuing patents, with sublicense rights · Covers Licensed Products and Licensed Methods · Non-exclusive license to associated Know-How with sublicense rights · Scoped to the therapeutic field of use
            </div>
          </div>
        </div>

        <div class="outcome-panel good">✓ Value created post-acquisition: new preclinical program at MUSC, radioprotection indication developed, Method of Use patent application filed by MUSC, and an exclusive license with sublicense rights secured by LifeRaft.</div>
      </div>
    </div>
  </ContentSection>

  <ContentSection dark title="EPIC Result Interpretation" intro="A failed primary endpoint is not the same as a failed molecule. The EPIC trial generated the world’s most comprehensive dataset on vaso-occlusive crisis and surfaced important insights into endpoint design that a next-generation trial could address. The safety story is the most commercially valuable output.">
    <div class="dual-list-panel">
      <div>
        <div class="column-title">What EPIC Established</div>
        <ul>
          <li>Clean safety profile in 388 patients ages 4–46 across 12 countries</li>
          <li>No patient deaths and no significant adverse-event differential vs. placebo</li>
          <li>Largest placebo-controlled sickle-cell trial ever completed</li>
          <li>One filed IND (EPIC) plus a draft IMPD (Heart Failure) the next owner can build upon immediately</li>
          <li>Comprehensive pharmacokinetic and clinical characterization</li>
        </ul>
      </div>
      <div>
        <div class="column-title">What EPIC Left Open</div>
        <ul>
          <li>Whether a redesigned endpoint would reveal signal in sickle cell disease</li>
          <li>Whether biomarker-selected patients would respond more strongly</li>
          <li>Efficacy in STEMI, ischemic stroke, TBI, and oral mucositis — never clinically tested</li>
          <li>Radioprotection — no clinical trial has ever been conducted in this indication</li>
        </ul>
      </div>
    </div>
  </ContentSection>

  <SiteCtaBand
    title="Human evidence changes the starting point."
    body="For a serious partner, Vepoloxamer is not just a mechanism slide. It is a molecule with human history, IND files, large clinical datasets, manufacturing-process documentation, and post-acquisition value creation."
    primaryHref="/partner/"
    primaryLabel="Discuss the Asset →"
    secondaryHref="/development/"
    secondaryLabel="View Development Path"
  />

  <SiteFooter />
  <FooterStrip />
</BaseLayout>
